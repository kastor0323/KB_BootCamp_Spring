<Appenders>

    <Console
            name="console"
            target="SYSTEM_OUT">

        <PatternLayout
                charset="UTF-8"
                pattern="%-5level %c(%M:%L) - %m%n"/>

    </Console>

</Appenders>

<Loggers>

<Logger
        name="org.scoula"
        level="DEBUG"
        additivity="false">

    <AppenderRef ref="console"/>

</Logger>

<Logger
        name="org.springframework"
        level="INFO"
        additivity="false">

    <AppenderRef ref="console"/>

</Logger>

<Root level="INFO">

    <AppenderRef ref="console"/>

</Root>

</Loggers>